# 必填：生产环境敏感信息
# 请复制为 .env 并修改：  cp .env.example .env
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成强密码
JWT_SECRET=请改成随机长字符串

# 硅基流动 API Key(用于学校简介向量化检索 bge-m3)
# 注册: https://siliconflow.cn  → 控制台新建令牌
SILICONFLOW_API_KEY=

# DeepSeek 官方 API Key(用于智能问答 LLM)
# 注册: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=
# 可选: 覆盖默认(base/model/限额)
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MAX_TOKENS=4096
# CHAT_MAX_TOOL_ROUNDS=6
# CHAT_RATE_PER_MIN=20

# 可选
JWT_EXPIRE_HOURS=12
HTTP_PORT=80
